  // ════════════════════════════════════════════════════════════════════

  MemAlloc :
    fn(size : u32) -> *(void),
  MemRealloc :
    fn(ptr : *(void), size : u32) -> *(void),
  MemFree :
    fn(ptr : *(void)) -> unit,

  // ════════════════════════════════════════════════════════════════════

    fn(dirPath : *(char)) -> *(char),
  GetWorkingDirectory :
    fn() -> *(char),
  GetApplicationDirectory :
    fn() -> *(char),
  MakeDirectory :
    fn(dirPath : *(char)) -> i32,
  ChangeDirectory :
    fn(dir : *(char)) -> bool,
  IsPathFile :
    fn(path : *(char)) -> bool,
  IsFileNameValid :
    fn(fileName : *(char)) -> bool,
  LoadDirectoryFiles :
    fn(dirPath : *(char)) -> FilePathList,
  LoadDirectoryFilesEx :
    fn(basePath : *(char), filter : *(char), scanSubdirs : bool) -> FilePathList,
  UnloadDirectoryFiles :
    fn(files : FilePathList) -> unit,
  IsFileDropped :
    fn() -> bool,
  LoadDroppedFiles :
    fn() -> FilePathList,
  UnloadDroppedFiles :
    fn(files : FilePathList) -> unit,


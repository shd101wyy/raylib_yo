  // ════════════════════════════════════════════════════════════════════

  LoadFileData :
    fn(fileName : *(char), dataSize : *(i32)) -> *(u8),
  UnloadFileData :
    fn(data : *(u8)) -> unit,
  SaveFileData :
    fn(fileName : *(char), data : *(void), dataSize : i32) -> bool,
  LoadFileText :
    fn(fileName : *(char)) -> *(char),
  UnloadFileText :
    fn(text : *(char)) -> unit,
  SaveFileText :
    fn(fileName : *(char), text : *(char)) -> bool,
  FileExists :
    fn(fileName : *(char)) -> bool,
  DirectoryExists :
    fn(dirPath : *(char)) -> bool,
  IsFileExtension :
    fn(fileName : *(char), ext : *(char)) -> bool,
  GetFileLength :
    fn(fileName : *(char)) -> i32,
  GetFileExtension :
    fn(fileName : *(char)) -> *(char),
  GetFileName :
    fn(filePath : *(char)) -> *(char),
  GetFileNameWithoutExt :
    fn(filePath : *(char)) -> *(char),
  GetDirectoryPath :
    fn(filePath : *(char)) -> *(char),

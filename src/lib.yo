// Comprehensive raylib bindings for Yo
// Covers all core raylib types, functions, and constants.
// Uses c_include with assigned struct types so Yo can construct/access C structs
// while the C compiler uses raylib.h's native definitions.

c_include "<raylib.h>",

  // ════════════════════════════════════════════════════════════════════
  // Types
  // ════════════════════════════════════════════════════════════════════

  (Color : Type) = struct(r : u8, g : u8, b : u8, a : u8),
  (Vector2 : Type) = struct(x : f32, y : f32),
  (Vector3 : Type) = struct(x : f32, y : f32, z : f32),
  (Vector4 : Type) = struct(x : f32, y : f32, z : f32, w : f32),
  (Matrix : Type) = struct(
    m0 : f32, m4 : f32, m8 : f32, m12 : f32,
    m1 : f32, m5 : f32, m9 : f32, m13 : f32,
    m2 : f32, m6 : f32, m10 : f32, m14 : f32,
    m3 : f32, m7 : f32, m11 : f32, m15 : f32
  ),
  (Rectangle : Type) = struct(x : f32, y : f32, width : f32, height : f32),
  (Image : Type) = struct(data : *(void), width : i32, height : i32, mipmaps : i32, format : i32),
  (Texture : Type) = struct(id : u32, width : i32, height : i32, mipmaps : i32, format : i32),
  (RenderTexture : Type) = struct(id : u32, texture : Texture, depth : Texture),
  (NPatchInfo : Type) = struct(source : Rectangle, left : i32, top : i32, right : i32, bottom : i32, layout : i32),
  (GlyphInfo : Type) = struct(value : i32, offsetX : i32, offsetY : i32, advanceX : i32, image : Image),
  (Font : Type) = struct(baseSize : i32, glyphCount : i32, glyphPadding : i32, texture : Texture, recs : *(Rectangle), glyphs : *(GlyphInfo)),
  (Camera3D : Type) = struct(position : Vector3, target : Vector3, up : Vector3, fovy : f32, projection : i32),
  (Camera2D : Type) = struct(offset : Vector2, target : Vector2, rotation : f32, zoom : f32),
  (Shader : Type) = struct(id : u32, locs : *(i32)),
  (MaterialMap : Type) = struct(texture : Texture, color : Color, value : f32),
  (Material : Type) = struct(shader : Shader, maps : *(MaterialMap), params : Array(f32, 4)),
  (Transform : Type) = struct(translation : Vector3, rotation : Vector4, scale : Vector3),
  (BoneInfo : Type) = struct(name : Array(char, 32), parent : i32),
  (ModelSkeleton : Type) = struct(boneCount : i32, bones : *(BoneInfo), bindPose : *(Transform)),
  (Mesh : Type) = struct(
    vertexCount : i32, triangleCount : i32,
    vertices : *(f32), texcoords : *(f32), texcoords2 : *(f32),
    normals : *(f32), tangents : *(f32), colors : *(u8), indices : *(u16),
    boneCount : i32, boneIndices : *(u8), boneWeights : *(f32),
    animVertices : *(f32), animNormals : *(f32),
    vaoId : u32, vboId : *(u32)
  ),
  (Model : Type) = struct(
    transform : Matrix,
    meshCount : i32, materialCount : i32,
    meshes : *(Mesh), materials : *(Material), meshMaterial : *(i32),
    skeleton : ModelSkeleton, currentPose : *(Transform), boneMatrices : *(Matrix)
  ),
  (ModelAnimation : Type) = struct(name : Array(char, 32), boneCount : i32, keyframeCount : i32, keyframePoses : *(*(Transform))),
  (Ray : Type) = struct(position : Vector3, direction : Vector3),
  (RayCollision : Type) = struct(hit : bool, distance : f32, point : Vector3, normal : Vector3),
  (BoundingBox : Type) = struct(min : Vector3, max : Vector3),
  (Wave : Type) = struct(frameCount : u32, sampleRate : u32, sampleSize : u32, channels : u32, data : *(void)),
  (AudioStream : Type) = struct(buffer : *(void), processor : *(void), sampleRate : u32, sampleSize : u32, channels : u32),
  (Sound : Type) = struct(stream : AudioStream, frameCount : u32),
  (Music : Type) = struct(stream : AudioStream, frameCount : u32, looping : bool, ctxType : i32, ctxData : *(void)),
  (VrDeviceInfo : Type) = struct(
    hResolution : i32, vResolution : i32,
    hScreenSize : f32, vScreenSize : f32,
    eyeToScreenDistance : f32, lensSeparationDistance : f32, interpupillaryDistance : f32,
    lensDistortionValues : Array(f32, 4), chromaAbCorrection : Array(f32, 4)
  ),
  (VrStereoConfig : Type) = struct(
    projection : Array(Matrix, 2), viewOffset : Array(Matrix, 2),
    leftLensCenter : Array(f32, 2), rightLensCenter : Array(f32, 2),
    leftScreenCenter : Array(f32, 2), rightScreenCenter : Array(f32, 2),
    scale : Array(f32, 2), scaleIn : Array(f32, 2)
  ),
  (FilePathList : Type) = struct(capacity : u32, count : u32, paths : *(*(char))),
  (AutomationEvent : Type) = struct(frame : u32, type : u32, params : Array(i32, 4)),
  (AutomationEventList : Type) = struct(capacity : u32, count : u32, events : *(AutomationEvent)),

  // ════════════════════════════════════════════════════════════════════
  // Window management
  // ════════════════════════════════════════════════════════════════════

  InitWindow :
    fn(width : i32, height : i32, title : *(char)) -> unit,
  CloseWindow :
    fn() -> unit,
  WindowShouldClose :
    fn() -> bool,
  IsWindowReady :
    fn() -> bool,
  IsWindowFullscreen :
    fn() -> bool,
  IsWindowHidden :
    fn() -> bool,
  IsWindowMinimized :
    fn() -> bool,
  IsWindowMaximized :
    fn() -> bool,
  IsWindowFocused :
    fn() -> bool,
  IsWindowResized :
    fn() -> bool,
  IsWindowState :
    fn(flag : u32) -> bool,
  SetWindowState :
    fn(flags : u32) -> unit,
  ClearWindowState :
    fn(flags : u32) -> unit,
  ToggleFullscreen :
    fn() -> unit,
  ToggleBorderlessWindowed :
    fn() -> unit,
  MaximizeWindow :
    fn() -> unit,
  MinimizeWindow :
    fn() -> unit,
  RestoreWindow :
    fn() -> unit,
  SetWindowIcon :
    fn(image : Image) -> unit,
  SetWindowIcons :
    fn(images : *(Image), count : i32) -> unit,
  SetWindowTitle :
    fn(title : *(char)) -> unit,
  SetWindowPosition :
    fn(x : i32, y : i32) -> unit,
  SetWindowMonitor :
    fn(monitor : i32) -> unit,
  SetWindowMinSize :
    fn(width : i32, height : i32) -> unit,
  SetWindowMaxSize :
    fn(width : i32, height : i32) -> unit,
  SetWindowSize :
    fn(width : i32, height : i32) -> unit,
  SetWindowOpacity :
    fn(opacity : f32) -> unit,
  SetWindowFocused :
    fn() -> unit,
  GetWindowHandle :
    fn() -> *(void),
  GetScreenWidth :
    fn() -> i32,
  GetScreenHeight :
    fn() -> i32,
  GetRenderWidth :
    fn() -> i32,
  GetRenderHeight :
    fn() -> i32,
  GetMonitorCount :
    fn() -> i32,
  GetCurrentMonitor :
    fn() -> i32,
  GetMonitorPosition :
    fn(monitor : i32) -> Vector2,
  GetMonitorWidth :
    fn(monitor : i32) -> i32,
  GetMonitorHeight :
    fn(monitor : i32) -> i32,
  GetMonitorPhysicalWidth :
    fn(monitor : i32) -> i32,
  GetMonitorPhysicalHeight :
    fn(monitor : i32) -> i32,
  GetMonitorRefreshRate :
    fn(monitor : i32) -> i32,
  GetWindowPosition :
    fn() -> Vector2,
  GetWindowScaleDPI :
    fn() -> Vector2,
  GetMonitorName :
    fn(monitor : i32) -> *(char),
  SetClipboardText :
    fn(text : *(char)) -> unit,
  GetClipboardText :
    fn() -> *(char),
  GetClipboardImage :
    fn() -> Image,
  EnableEventWaiting :
    fn() -> unit,
  DisableEventWaiting :
    fn() -> unit,

  // ════════════════════════════════════════════════════════════════════
  // Cursor
  // ════════════════════════════════════════════════════════════════════

  ShowCursor :
    fn() -> unit,
  HideCursor :
    fn() -> unit,
  IsCursorHidden :
    fn() -> bool,
  EnableCursor :
    fn() -> unit,
  DisableCursor :
    fn() -> unit,
  IsCursorOnScreen :
    fn() -> bool,

  // ════════════════════════════════════════════════════════════════════
  // Drawing
  // ════════════════════════════════════════════════════════════════════

  ClearBackground :
    fn(color : Color) -> unit,
  BeginDrawing :
    fn() -> unit,
  EndDrawing :
    fn() -> unit,
  BeginMode2D :
    fn(camera : Camera2D) -> unit,
  EndMode2D :
    fn() -> unit,
  BeginMode3D :
    fn(camera : Camera3D) -> unit,
  EndMode3D :
    fn() -> unit,
  BeginTextureMode :
    fn(target : RenderTexture) -> unit,
  EndTextureMode :
    fn() -> unit,
  BeginShaderMode :
    fn(shader : Shader) -> unit,
  EndShaderMode :
    fn() -> unit,
  BeginBlendMode :
    fn(mode : i32) -> unit,
  EndBlendMode :
    fn() -> unit,
  BeginScissorMode :
    fn(x : i32, y : i32, width : i32, height : i32) -> unit,
  EndScissorMode :
    fn() -> unit,
  BeginVrStereoMode :
    fn(config : VrStereoConfig) -> unit,
  EndVrStereoMode :
    fn() -> unit,

  // ════════════════════════════════════════════════════════════════════
  // VR
  // ════════════════════════════════════════════════════════════════════

  LoadVrStereoConfig :
    fn(device : VrDeviceInfo) -> VrStereoConfig,
  UnloadVrStereoConfig :
    fn(config : VrStereoConfig) -> unit,

  // ════════════════════════════════════════════════════════════════════
  // Shader
  // ════════════════════════════════════════════════════════════════════

  LoadShader :
    fn(vsFileName : *(char), fsFileName : *(char)) -> Shader,
  LoadShaderFromMemory :
    fn(vsCode : *(char), fsCode : *(char)) -> Shader,
  IsShaderValid :
    fn(shader : Shader) -> bool,
  GetShaderLocation :
    fn(shader : Shader, uniformName : *(char)) -> i32,
  GetShaderLocationAttrib :
    fn(shader : Shader, attribName : *(char)) -> i32,
  SetShaderValue :
    fn(shader : Shader, locIndex : i32, value : *(void), uniformType : i32) -> unit,
  SetShaderValueV :
    fn(shader : Shader, locIndex : i32, value : *(void), uniformType : i32, count : i32) -> unit,
  SetShaderValueMatrix :
    fn(shader : Shader, locIndex : i32, mat : Matrix) -> unit,
  SetShaderValueTexture :
    fn(shader : Shader, locIndex : i32, texture : Texture) -> unit,
  UnloadShader :
    fn(shader : Shader) -> unit,

  // ════════════════════════════════════════════════════════════════════
  // Screen-space
  // ════════════════════════════════════════════════════════════════════

  GetScreenToWorldRay :
    fn(position : Vector2, camera : Camera3D) -> Ray,
  GetScreenToWorldRayEx :
    fn(position : Vector2, camera : Camera3D, width : i32, height : i32) -> Ray,
  GetWorldToScreen :
    fn(position : Vector3, camera : Camera3D) -> Vector2,
  GetWorldToScreenEx :
    fn(position : Vector3, camera : Camera3D, width : i32, height : i32) -> Vector2,
  GetWorldToScreen2D :
    fn(position : Vector2, camera : Camera2D) -> Vector2,
  GetScreenToWorld2D :
    fn(position : Vector2, camera : Camera2D) -> Vector2,
  GetCameraMatrix :
    fn(camera : Camera3D) -> Matrix,
  GetCameraMatrix2D :
    fn(camera : Camera2D) -> Matrix,

  // ════════════════════════════════════════════════════════════════════
  // Timing
  // ════════════════════════════════════════════════════════════════════

  SetTargetFPS :
    fn(fps : i32) -> unit,
  GetFrameTime :
    fn() -> f32,
  GetTime :
    fn() -> f64,
  GetFPS :
    fn() -> i32,

  // ════════════════════════════════════════════════════════════════════
  // Custom frame control
  // ════════════════════════════════════════════════════════════════════

  SwapScreenBuffer :
    fn() -> unit,
  PollInputEvents :
    fn() -> unit,
  WaitTime :
    fn(seconds : f64) -> unit,

  // ════════════════════════════════════════════════════════════════════
  // Random
  // ════════════════════════════════════════════════════════════════════

  SetRandomSeed :
    fn(seed : u32) -> unit,
  GetRandomValue :
    fn(min : i32, max : i32) -> i32,
  LoadRandomSequence :
    fn(count : u32, min : i32, max : i32) -> *(i32),
  UnloadRandomSequence :
    fn(sequence : *(i32)) -> unit,

  // ════════════════════════════════════════════════════════════════════
  // Misc
  // ════════════════════════════════════════════════════════════════════

  TakeScreenshot :
    fn(fileName : *(char)) -> unit,
  SetConfigFlags :
    fn(flags : u32) -> unit,
  OpenURL :
    fn(url : *(char)) -> unit,

  // ════════════════════════════════════════════════════════════════════
  // Logging
  // ════════════════════════════════════════════════════════════════════

  SetTraceLogLevel :
    fn(logLevel : i32) -> unit,
  TraceLog :
    fn(logLevel : i32, text : *(char), ...) -> unit,

  // ════════════════════════════════════════════════════════════════════
